# Copy this file to .env and fill in your real values.
# .env is gitignored and must NEVER be committed.

# ── LLM provider (auto-detected: GEMINI > GROQ > ANTHROPIC) ────
# LLM_PROVIDER=gemini

# Google Gemini (free tier) — https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-flash-latest

# Groq (free, rate-limited) — https://console.groq.com
# GROQ_API_KEY=your_groq_api_key_here
# GROQ_MODEL=llama-3.3-70b-versatile

# Anthropic Claude (paid) — https://console.anthropic.com
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── App login (Gradio auth) ───────────────────────────────────
APP_USERNAME=spicenutrition
APP_PASSWORD=changeme123

# ── Deployment (Hugging Face) — do NOT commit the real token ──
# HF_TOKEN=hf_your_write_token_here

# ── Rate limiter (optional) ───────────────────────────────────
# RATE_LIMIT_PER_MINUTE=20
# RATE_LIMIT_PER_DAY=200
